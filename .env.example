# HeartGold / BizHawk runtime
GAME_PROFILE=heartgold
PYTHON_BASE_URL=http://127.0.0.1:8010
BIZHAWK_EXE=J:\path\to\EmuHawk.exe
HEARTGOLD_ROM=J:\path\to\Pokemon - HeartGold Version (USA).nds
HEARTGOLD_RUNTIME_DIR=.heartgold_runtime
HEARTGOLD_BRIDGE_PORT=8010

# Launch and emulator behavior
AUTO_LAUNCH_EMULATOR=true
HEARTGOLD_LAUNCH_MIN_FRAME=600
HEARTGOLD_SPEED_MODE=100
HEARTGOLD_ALLOW_FAST_FORWARD=false
HEARTGOLD_HEARTBEAT_MAX_AGE_S=5.0
HEARTGOLD_BOOTSTRAP_ON_LAUNCH=false
HEARTGOLD_AUTOSAVE_BEFORE_RESTART=true

# Observation surface
HEARTGOLD_OBSERVATION_MODE=ram_assisted
HEARTGOLD_EXPOSE_ALL_DECODED_RAM=true
HEARTGOLD_EXPOSE_ORACLE=false
HEARTGOLD_STATE_CONFIDENCE_REQUIRED=true
HEARTGOLD_MODEL_IMAGE_SCALE=2

# Local Codex Desktop backend for HeartGold.
# This mode does not require OPENAI_API_KEY and is the primary Windows lane.
AGENT_PROVIDER=codex-desktop
CODEX_DESKTOP_MODEL=gpt-5.5
CODEX_DESKTOP_REASONING_EFFORT=xhigh

# Optional Codex CLI automation backend.
# AGENT_PROVIDER=codex-cli
# CODEX_MODEL=gpt-5.5
# CODEX_REASONING_EFFORT=xhigh

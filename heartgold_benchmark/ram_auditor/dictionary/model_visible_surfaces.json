    {
      "pattern": "\\b(?:oracle|monitor_only|harness_diagnostics|raw[-_ ]?address|address[-_ ]?candidate|mock[-_ ]?only|tasvideos)\\b",
      "flags": "i",
      "reason": "monitor_only_marker"
    }
  ],
  "global_forbidden_model_visible_value_patterns": [
    {
      "pattern": "\\b(?:oracle|monitor_only|harness_diagnostics|raw[-_ ]?address|address[-_ ]?candidate|script[-_ ]?id|event[-_ ]?flag)\\b",
      "flags": "i",
      "reason": "monitor_only_value_marker"
    }

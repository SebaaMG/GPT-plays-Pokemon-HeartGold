{
  "schema": "heartgold_ram_surface_dictionary_v2",
  "purpose": "Runtime policy for the HeartGold ram_assisted model-visible observation surface.",
  "decoding_policy": {
    "observation_rule": "Expose the current DS screenshot plus decoded current RAM gameplay state through the agent observation endpoint.",
    "monitor_boundary_rule": "Runtime dumps, raw pointers, raw flags, route plans, and future-state helpers stay outside gameplay observations."
  },
